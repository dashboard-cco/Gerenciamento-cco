/*
========================================================
INTRANET KPI CCO • SLU
========================================================

SISTEMA:
- Leitura automática de TODAS as abas da planilha
- Consolidação automática dos KPI’s
- Painel Executivo
- Execução P1 a P12
- Indicadores operacionais
- Gráficos automáticos
- Relatórios executivos

REGRAS PRINCIPAIS:
1. O sistema analisa TODAS as sheets
2. O Painel Executivo é a base principal
3. Valor = Valor Fixo × Acumulado do Mês
4. Índice máximo = 100%
5. P1 e P2 NÃO mostram valor estimado
========================================================
*/


/*
========================================================
VARIÁVEIS GLOBAIS
========================================================
*/

let painelExecutivo = [];

let operacoes = [];

let todasAsAbasImportadas = [];

let graficoExecucao = null;

let graficoAcumulado = null;


/*
========================================================
INICIALIZAÇÃO DO SISTEMA
========================================================
*/

document.addEventListener("DOMContentLoaded", () => {

  atualizarData();

  const inputArquivo =
    document.getElementById("arquivoExcel");

  if (inputArquivo) {

    inputArquivo.addEventListener(
      "change",
