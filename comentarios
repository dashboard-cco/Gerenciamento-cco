/*
========================================================
ATUALIZA DATA DO TOPO
========================================================
*/

function atualizarData() {

  const dataAtual =
    document.getElementById("dataAtual");

  if (!dataAtual) return;

  dataAtual.innerText =
    new Date().toLocaleDateString("pt-BR", {

      weekday: "long",

      day: "2-digit",

      month: "long",

      year: "numeric"
    });
}


/*
========================================================
IMPORTAÇÃO DAS PLANILHAS
========================================================

ESTA É A PRINCIPAL FUNÇÃO DO SISTEMA

FLUXO:
1. Lê arquivo Excel
2. Percorre TODAS as abas
3. Converte para JSON
4. Normaliza colunas
5. Gera Painel Executivo
6. Gera Operações
========================================================
*/

async function importarArquivos(evento) {

  const arquivos =
    Array.from(evento.target.files || []);

  if (!arquivos.length) return;

  /*
  ======================================================
  LIMPA MEMÓRIA
  ======================================================
  */

  painelExecutivo = [];

  operacoes = [];

  todasAsAbasImportadas = [];

  /*
  ======================================================
  GUARDA TODAS AS ABAS
  ======================================================
  */

  const abasPorNome = {};

  /*
  ======================================================
  PERCORRE TODOS OS ARQUIVOS
  ======================================================
  */

  for (const arquivo of arquivos) {

    /*
    ====================================================
    CONVERTE ARQUIVO EM BUFFER
    ====================================================
    */

    const buffer =
      await arquivo.arrayBuffer();

    /*
    ====================================================
    LÊ O EXCEL
    ====================================================
    */

    const workbook = XLSX.read(buffer, {

      type: "array",

      cellDates: true
    });

    /*
    ====================================================
    PERCORRE TODAS AS SHEETS
    ====================================================
    */

    workbook.SheetNames.forEach(nomeAba => {

      /*
      ==================================================
      PEGA A ABA
      ==================================================
      */

      const sheet =
        workbook.Sheets[nomeAba];

      /*
      ==================================================
      CONVERTE ABA EM JSON
      ==================================================
      */

      const dados =
        XLSX.utils.sheet_to_json(sheet, {

          defval: "",

          raw: false
        });

      /*
      ==================================================
      NORMALIZA COLUNAS
      ==================================================
      */

      const dadosNormalizados =
        dados.map(linha =>
          normalizarObjeto(linha)
        );

      /*
      ==================================================
      SALVA ABA PELO NOME
      ==================================================
      */

      abasPorNome[
        normalizar(nomeAba)
      ] = dadosNormalizados;

      /*
      ==================================================
      SALVA CONTROLE DE ABAS
      ==================================================
      */

      todasAsAbasImportadas.push({

        arquivo: arquivo.name,

        aba: nomeAba,

        dados: dadosNormalizados
      });
    });
  }

  /*
  ======================================================
  GERA PAINEL EXECUTIVO
  ======================================================
  */

  gerarPainelExecutivoCompleto(
    abasPorNome
  );

  /*
  ======================================================
  GERA OPERAÇÕES
  ======================================================
  */

  gerarOperacoes(abasPorNome);

  /*
  ======================================================
  MOSTRA INFORMAÇÕES DA IMPORTAÇÃO
  ======================================================
  */

  preencherTexto(
    "nomeArquivo",

    `${arquivos.length} arquivo(s) importado(s) | ${todasAsAbasImportadas.length} aba(s) lida(s)`
  );

  /*
  ======================================================
  ATUALIZA INTERFACE
  ======================================================
  */

  atualizarTudo();

  alert(
    "Planilha analisada com sucesso!"
  );

  evento.target.value = "";
}


/*
========================================================
GERA PAINEL EXECUTIVO COMPLETO
========================================================

ABAS ANALISADAS:
- Painel Executivo
- Resumo Diário
- P5
- P6
- P9
========================================================
*/

function gerarPainelExecutivoCompleto(abas) {

  /*
  ======================================================
  PEGA AS ABAS
  ======================================================
  */

  const painel =
    abas["painel executivo"] || [];

  const resumo =
    abas["resumo_diario"] || [];

  const p5 =
    abas["p5"] || [];

  const p6 =
    abas["p6"] || [];

  const p9 =
    abas["p9"] || [];

  /*
  ======================================================
  CALCULA ACUMULADOS
  ======================================================
  */

  const acumulados =
    calcularAcumuladosPorServico(

      resumo,

      p5,

      p6,

      p9
    );

  /*
  ======================================================
  MONTA O PAINEL FINAL
  ======================================================
  */

  painelExecutivo =
    painel.map(linha => {

      /*
      ==================================================
      IDENTIFICA SERVIÇO
      ==================================================
      */

      const servico =
        linha.servico ||
        linha.programa ||
        linha.codigo ||
        "";

      /*
      ==================================================
      NOME SERVIÇO
      ==================================================
      */

      const nomeServico =
        linha.nome_servico ||
        linha.descricao ||
        "";

      /*
      ==================================================
      ACUMULADO ORIGINAL DA PLANILHA
      ==================================================
      */

      const acumuladoOriginal =
        numero(

          linha.acumulado_mes ||

          linha.acumulado ||

          linha.executado
        );

      /*
      ==================================================
      ACUMULADO CALCULADO
      ==================================================
      */

      const acumuladoCalculado =
        acumulados[servico];

      /*
      ==================================================
      USA CALCULADO OU ORIGINAL
      ==================================================
      */

      const acumuladoMes =

        acumuladoCalculado !== undefined

          ? acumuladoCalculado

          : acumuladoOriginal;

      /*
      ==================================================
      PREVISTO DO MÊS
      ==================================================
      */

      const previstoMes =
        numero(

          linha.previsto_mes ||

          linha.meta_mes ||

          linha.previsto ||

          linha.meta
        );

      /*
      ==================================================
      VALOR FIXO
      ==================================================

      REGRA:
      VALOR FINAL =
      VALOR FIXO × ACUMULADO MÊS
      */

      const valorFixo =
        numero(

          linha.valor ||

          linha.valor_fixo ||

          linha.valor_unitario
        );

      /*
      ==================================================
      RETORNA OBJETO FINAL
      ==================================================
      */

      return {

        servico,

        nome_servico: nomeServico,

        acumulado_mes: acumuladoMes,

        semana_1:
          numero(linha.semana_1),

        semana_2:
          numero(linha.semana_2),

        semana_3:
          numero(linha.semana_3),

        semana_4:
          numero(linha.semana_4),

        medicao:
          linha.medicao || "",

        previsto_mes:
          previstoMes,

        /*
        ================================================
        ÍNDICE EXECUÇÃO
        ================================================

        LIMITADO EM 100%
        */

        porcentagem_execucao:

          calcularIndiceExecucao(

            acumuladoMes,

            previstoMes
          ),

        /*
        ================================================
        VALOR FINANCEIRO
        ================================================

        REGRA:
        VALOR FIXO × ACUMULADO
        */

        valor_fixo:
          valorFixo,

        valor:
          valorFixo *
          acumuladoMes,

        /*
        ================================================
        STATUS
        ================================================
        */

        status:

          acumuladoMes > 0

            ? "Com dados"

            : "Sem dados"
      };
    });
}


/*
========================================================
CALCULA ACUMULADOS
========================================================

EXEMPLOS:
P1 → Peso
P2 → Viagens
P5 → KM
P9 → Equipes
========================================================
*/

function calcularAcumuladosPorServico(

  resumo,

  p5,

  p6,

  p9
) {

  const acumulados = {};

  /*
  ======================================================
  RESUMO DIÁRIO
  ======================================================
  */

  resumo.forEach(linha => {

    const servico =

      linha.servicos_p ||

      linha.servico ||

      "";

    if (!servico) return;

    if (!acumulados[servico]) {

      acumulados[servico] = 0;
    }

    /*
    ====================================================
    P1 / P4 / P12 → PESO
    ====================================================
    */

    if (

      servico === "P1" ||

      servico === "P4" ||

      servico === "P12"
    ) {

      acumulados[servico] +=

        numero(

          linha.peso_t ||

          linha.peso_total
        );
    }

    /*
    ====================================================
    P2 → VIAGENS
    ====================================================
    */

    else if (

      servico === "P2.1" ||

      servico === "P2.2"
    ) {

      acumulados[servico] +=

        numero(

          linha.qtd_viagens ||

          linha.viagens
        );
    }
  });

  /*
  ======================================================
  P5 → KM
  ======================================================
  */

  if (p5.length) {

    acumulados["P5"] =

      p5.reduce((soma, linha) => {

        return soma +

          numero(
            linha.km_executado
          );

      }, 0);
  }

  /*
  ======================================================
  P6 → KM
  ======================================================
  */

  if (p6.length) {

    acumulados["P6"] =

      p6.reduce((soma, linha) => {

        return soma +

          numero(
            linha.km_executado
          );

      }, 0);
  }

  /*
  ======================================================
  P9 → EQUIPES
  ======================================================
  */

  if (p9.length) {

    acumulados["P9"] =

      p9.reduce((soma, linha) => {

        return soma +

          numero(
            linha.qtd_equipe
          );

      }, 0);
  }

  return acumulados;
}


