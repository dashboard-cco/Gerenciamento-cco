});


/*
========================================================
ATUALIZA TODOS OS COMPONENTES
========================================================
*/

function atualizarTudo() {

  renderKPIs();

  renderPainelExecutivo();

  renderContratoExecutivo();

  renderResumoExecutivo();

  renderAlertasExecutivos();

  renderTabelaPerguntas();

  renderFiltros();

  renderTabelaDados();

