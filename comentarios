/*
========================================================
CÁLCULO DO ÍNDICE
========================================================

REGRA:
NUNCA PASSA DE 100%
========================================================
*/

function calcularIndiceExecucao(

  acumulado,

  previsto
) {

  const realizado =
    numero(acumulado);

  const meta =
    numero(previsto);

  if (meta <= 0) return 0;

  const indice =

    (realizado / meta) * 100;

  /*
  ======================================================
  LIMITA EM 100%
  ======================================================
  */

  return Math.min(indice, 100);
}


/*
========================================================
NORMALIZA OBJETO
========================================================

EXEMPLO:
"Previsto Mês"

VIRA:
previsto_mes
========================================================
*/

function normalizarObjeto(objeto) {

  const novo = {};

  Object.keys(objeto).forEach(chave => {

    const novaChave =

      normalizar(chave)

      .replace(/ª/g, "a")

      .replace(/º/g, "o")

      .replace(/\s+/g, "_")

      .replace(/[^\w]/g, "");

    novo[novaChave] =
      objeto[chave];
  });

  return novo;
}


/*
========================================================
CONVERTE TEXTO EM NÚMERO
========================================================
*/

function numero(valor) {

  if (

    valor === null ||

    valor === undefined ||

    valor === ""
  ) {

    return 0;
  }

  if (
    typeof valor === "number"
  ) {

    return valor;
  }

  let texto =
    String(valor)

    .replace(/[^\d,.-]/g, "")

    .replace(/\./g, "")

    .replace(",", ".");

  const convertido =
    Number(texto);

  return isNaN(convertido)

    ? 0

    : convertido;
}


/*
========================================================
FORMATAÇÕES
========================================================
*/

function formatarNumero(valor) {

  return numero(valor)

    .toLocaleString("pt-BR", {

      minimumFractionDigits: 0,

      maximumFractionDigits: 2
    });
}

function formatarMoeda(valor) {

  return numero(valor)

    .toLocaleString("pt-BR", {

      style: "currency",

      currency: "BRL"
    });
}


/*
========================================================
NORMALIZA TEXTO
========================================================
*/

function normalizar(texto) {

  return String(texto || "")

    .toLowerCase()

    .normalize("NFD")

    .replace(/[\u0300-\u036f]/g, "")

    .trim();
}